# Template environment file. Copy to `.env` and adjust as needed.
#
# DATABASE_URL: connection string for the Prisma client. The default
#   points at the Postgres container defined in `docker-compose.yml`.
# SESSION_SECRET: HMAC key used by `lib/session.ts` to sign the
#   `phu_session` cookie. Replace with a strong random value before
#   running anywhere other than localhost; never reuse the dev value.
# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET: Google OAuth app
#   credentials for attendee login.
# GOOGLE_OAUTH_REDIRECT_URI: optional override. If omitted, the app uses
#   `${request origin}/api/auth/google/callback`.
# APP_BASE_URL: optional browser-facing base URL for OAuth redirects. Use
#   localhost or your laptop IP, never 0.0.0.0.

DATABASE_URL="postgresql://phuconcert:phuconcert@localhost:5432/phuconcert?schema=public"
SESSION_SECRET="replace-this-local-dev-secret"
APP_BASE_URL="http://localhost:3000"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"
GOOGLE_OAUTH_REDIRECT_URI="http://YOUR_LAPTOP_IP:3000/api/auth/google/callback" # ADD YOUR LAPTOP IP ADDRESS HERE FOR TESTING ON OTHER DEVICES
