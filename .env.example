# Template environment file. Copy to `.env` and adjust as needed.
#
# DATABASE_URL: connection string for the Prisma client. The default
#   points at the Postgres container defined in `docker-compose.yml`.
# SESSION_SECRET: HMAC key used by `lib/session.ts` to sign the
#   `phu_session` cookie. Replace with a strong random value before
#   running anywhere other than localhost; never reuse the dev value.
# GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET: Google OAuth app
#   credentials for attendee login.
# GOOGLE_OAUTH_REDIRECT_URI: optional override. Use it when the public URL is
#   not the same as the incoming request origin, such as a Cloudflare tunnel.
# APP_BASE_URL: browser-facing base URL for OAuth redirects and QR approval
#   links. Use localhost for same-machine tests or an HTTPS tunnel/domain for
#   phone testing. Never use 0.0.0.0 as a browser-facing URL.

DATABASE_URL="postgresql://phuconcert:phuconcert@localhost:5432/phuconcert?schema=public"
SESSION_SECRET="replace-this-local-dev-secret"
APP_BASE_URL="http://localhost:3000"
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# For phone testing with Google OAuth, prefer an HTTPS Cloudflare tunnel:
# 1. Start the app on localhost:3000.
# 2. Run `npm run tunnel`.
# 3. Copy the printed https://*.trycloudflare.com URL.
# 4. Run `npm run tunnel:env -- https://example.trycloudflare.com`.
# 5. Add the exact callback URL in the Google OAuth client, then restart Next.
# APP_BASE_URL="https://example.trycloudflare.com"
# GOOGLE_OAUTH_REDIRECT_URI="https://example.trycloudflare.com/api/auth/google/callback"

# For plain LAN testing without Google OAuth, replace both values with your
# real laptop IP. Google OAuth generally requires an authorized exact callback.
# APP_BASE_URL="http://192.168.1.10:3000"
# GOOGLE_OAUTH_REDIRECT_URI="http://192.168.1.10:3000/api/auth/google/callback"
