# PHUConcert environment variables.
# Copy this file to `.env` and adjust values as needed.
#
# DATABASE_URL    — Prisma connection string. The default matches the
#                   Postgres container in docker-compose.yml.
# SESSION_SECRET  — HMAC key for the phu_session cookie. Replace with a
#                   strong random value before deploying anywhere public.
# APP_BASE_URL    — The browser-facing URL. Used for QR approval links.
#                   For local-only testing:  http://localhost:3000
#                   For LAN phone testing:   http://<your-ip>:3000
#                   For camera/QR scanning:  use `npm run dev:tunnel`
#                     (the tunnel script updates this automatically)

DATABASE_URL="postgresql://phuconcert:phuconcert@localhost:5432/phuconcert?schema=public"
SESSION_SECRET="replace-this-local-dev-secret"
APP_BASE_URL="http://localhost:3000"
